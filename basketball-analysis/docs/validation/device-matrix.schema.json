{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shotiq.local/schemas/device-matrix.schema.json",
  "title": "ShotIQ physical device release matrix",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "app", "commitSha", "measuredAt", "runs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "app": { "const": "ShotIQ" },
    "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "measuredAt": { "type": "string", "format": "date-time" },
    "runs": {
      "type": "array",
      "minItems": 16,
      "maxItems": 16,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "device", "mode", "orientation", "camera", "commitSha", "metrics", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "device": { "enum": ["iPhone 11", "iPhone 12"] },
          "mode": { "enum": ["safari", "native"] },
          "orientation": { "enum": ["portrait", "landscape"] },
          "camera": { "enum": ["front", "rear"] },
          "commitSha": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
          "metrics": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fps", "poseCompleteness", "shotPrecision", "shotRecall", "makeMissAccuracy", "phaseError"],
            "properties": {
              "fps": { "type": "number", "minimum": 0 },
              "poseCompleteness": { "type": "number", "minimum": 0, "maximum": 1 },
              "shotPrecision": { "type": "number", "minimum": 0, "maximum": 1 },
              "shotRecall": { "type": "number", "minimum": 0, "maximum": 1 },
              "makeMissAccuracy": { "type": "number", "minimum": 0, "maximum": 1 },
              "phaseError": { "type": "number", "minimum": 0, "maximum": 1 }
            }
          },
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["fixtureId", "notes"],
            "properties": {
              "fixtureId": { "type": "string", "minLength": 1 },
              "notes": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
