{
  "name": "basketball-analysis",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:mac": "tauri build --target universal-apple-darwin",
    "tauri:build:win": "tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:linux": "tauri build --target x86_64-unknown-linux-gnu",
    "cap": "cap",
    "cap:build": "node scripts/build-capacitor.js",
    "cap:build:ios": "node scripts/build-capacitor.js ios",
    "cap:sync": "cap sync",
    "cap:sync:ios": "cap sync ios",
    "cap:open:ios": "cap open ios",
    "ios:dev": "npm run cap:build:ios && cap open ios",
    "ios:build": "CAPACITOR_BUILD=true npm run build && cap sync ios"
  },
