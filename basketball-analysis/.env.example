# ============================================================
# SHOTIQ AI — Environment Variables
# ============================================================
# Copy this file to ".env" for local dev, and set the SAME keys
# in your hosting provider's dashboard (the "Environment Variables"
# or "Secrets" section) for production.
#
# Sections are ordered REQUIRED -> RECOMMENDED -> OPTIONAL.
# The app degrades gracefully (falls back) when OPTIONAL keys are
# missing, but REQUIRED keys must be set for the core flow to work.
# ============================================================


# ------------------------------------------------------------
# REQUIRED — the app's core flow needs these
# ------------------------------------------------------------

# PostgreSQL database (Prisma). Use a managed DB such as Neon/Supabase/RDS.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Google AI Studio (Gemini) — primary Vision AI for shot analysis.
# Get a free key at https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-studio-key"

# Secret used to sign login session tokens (JWT). MUST be a long random string.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-long-random-secret"

# Public URL of the deployed app (used by auth). In production set your real domain.
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 — stores uploaded photos/videos.
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-s3-bucket-name"


# ------------------------------------------------------------
# RECOMMENDED — needed for full feature set
# ------------------------------------------------------------

# Roboflow — basketball/object detection.
ROBOFLOW_API_KEY="your-roboflow-api-key"

# Shotstack — renders annotated visualization videos.
SHOTSTACK_API_KEY="your-shotstack-production-key"
SHOTSTACK_SANDBOX_API_KEY="your-shotstack-sandbox-key"

# Pose-detection backend (HuggingFace Space / Python service).
NEXT_PUBLIC_HYBRID_API_URL="https://your-pose-backend.hf.space"


# ------------------------------------------------------------
# OPTIONAL — LLM fallbacks and extra integrations
# (the LLM router uses these only when Gemini is unavailable)
# ------------------------------------------------------------

OPENAI_API_KEY=""
HUGGINGFACE_API_KEY=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_AI_API_KEY=""

# Optional public endpoints (mobile/desktop builds, super-resolution, video, maps)
NEXT_PUBLIC_API_URL=""
NEXT_PUBLIC_MOBILE_API_URL=""
NEXT_PUBLIC_VIDEO_API_URL=""
NEXT_PUBLIC_REALESRGAN_SPACE_URL=""
NEXT_PUBLIC_MAPBOX_TOKEN=""
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Python data scraper (admin/data-collection only)
PYTHON_SCRAPER_URL=""
SCRAPER_API_KEY=""
